(module math
  (fn abs x int -> int
    (if (lt x 0)
      (ret (neg x)))
    (ret x))

  (fn abs_float x float -> float
    (if (lt x 0.0)
      (ret (neg x)))
    (ret x))

  (fn min a int b int -> int
    (if (lt a b)
      (ret a))
    (ret b))

  (fn max a int b int -> int
    (if (gt a b)
      (ret a))
    (ret b))

  (fn min_float a float b float -> float
    (if (lt a b)
      (ret a))
    (ret b))

  (fn max_float a float b float -> float
    (if (gt a b)
      (ret a))
    (ret b)))
