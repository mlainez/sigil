(module validation
  (fn in_range val_num int min_val int max_val int -> bool
    (ret (and (ge val_num min_val) (le val_num max_val))))

  (fn in_range_float val_num float min_val float max_val float -> bool
    (ret (and (ge val_num min_val) (le val_num max_val))))

  (fn is_positive i int -> bool
    (ret (gt i 0)))

  (fn is_negative i int -> bool
    (ret (lt i 0)))

  (fn is_zero i int -> bool
    (ret (eq i 0)))

  (fn is_positive_float f float -> bool
    (ret (gt f 0.0)))

  (fn is_negative_float f float -> bool
    (ret (lt f 0.0)))

  (fn is_zero_float f float -> bool
    (ret (eq f 0.0)))

  (fn is_divisible_by n int divisor int -> bool
    (ret (eq (mod n divisor) 0))))
