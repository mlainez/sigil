(module regex
  (fn compile pattern string -> string
    (ret (regex_compile pattern)))
  
  (fn match pat string text string -> bool
    (ret (regex_match pat text)))
  
  (fn find pat string text string -> string
    (ret (regex_find pat text)))
  
  (fn find_all pat string text string -> array
    (ret (regex_find_all pat text)))
  
  (fn replace pat string text string replacement string -> string
    (ret (regex_replace pat text replacement))))
