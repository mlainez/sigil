(set rows (split $0 ";"))
(set totals {})
(for i 1 (len rows)
  (set parts (split (array_get rows i) ","))
  (set c (array_get parts 0))
  (set a (int (array_get parts 1)))
  (set totals (map_set totals c (add (get_or totals c 0) a))))
(for-each k (sort (map_keys totals))
  (println (fmt "{}: {}" k (map_get totals k))))
