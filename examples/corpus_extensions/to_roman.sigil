(set n #0)
(set vals [1000 900 500 400 100 90 50 40 10 9 5 4 1])
(set syms ["M" "CM" "D" "CD" "C" "XC" "L" "XL" "X" "IX" "V" "IV" "I"])
(set result "")
(set i 0)
(while (lt i (len vals))
  (set v (array_get vals i))
  (set s (array_get syms i))
  (while (ge n v)
    (set result (string_concat result s))
    (set n (sub n v)))
  (set i (add i 1)))
(println result)
