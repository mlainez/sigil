(set cs (chars $0))
(set cur (first cs))
(set cnt 1)
(set out "")
(for-each c (rest cs)
  (if (eq c cur)
    (set cnt (+ cnt 1)))
  (if (ne c cur)
    (set out (join [out cur (str cnt)] "")))
  (if (ne c cur)
    (set cnt 1))
  (if (ne c cur)
    (set cur c)))
(println (join [out cur (str cnt)] ""))
