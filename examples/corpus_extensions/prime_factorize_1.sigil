(set n #0)
(set parts [])
(set d 2)
(while (le (mul d d) n)
  (set k 0)
  (while (eq (mod n d) 0)
    (set n (div n d))
    (set k (add k 1)))
  (cond
    ((gt k 1) (push parts (fmt "{}^{}" d k)))
    ((eq k 1) (push parts (str d))))
  (set d (add d 1)))
(if (gt n 1)
  (push parts (str n)))
(println (join parts " * "))
