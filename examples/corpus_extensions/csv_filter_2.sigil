(set rows (split $0 ";"))
(set parts (split $1 "="))
(set header (split (array_get rows 0) ","))
(set idx (array_index_of header (array_get parts 0)))
(set val (array_get parts 1))
(for i 1 (len rows)
  (set row (array_get rows i))
  (set fields (split row ","))
  (if (eq (array_get fields idx) val)
    (println row)))
