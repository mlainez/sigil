(set stack array [])
(for-each token string (split $0 " ")
  (cond
    ((in token ["+" "-" "*" "/"])
     (set b int (pop stack))
     (set a int (pop stack))
     (cond
       ((eq token "+") (push stack (+ a b)))
       ((eq token "-") (push stack (- a b)))
       ((eq token "*") (push stack (* a b)))
       ((eq token "/") (push stack (/ a b)))))
    (true (push stack (str->int token)))))
(println (first stack))
