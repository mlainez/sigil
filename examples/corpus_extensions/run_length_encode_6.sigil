(set s $0)
(set cs (chars s))
(set n (len cs))
(set result "")
(set i 0)
(while (lt i n)
  (set c (array_get cs i))
  (set count 1)
  (while (and (lt (add i count) n) (eq (array_get cs (add i count)) c))
    (set count (add count 1)))
  (set result (string_concat result (fmt "{}{}" c count)))
  (set i (add i count)))
(println result)
