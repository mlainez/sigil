(set s $0)
(set n (len s))
(set i 0)
(while (lt i n)
  (set ch (string_slice s i 1))
  (cond
    ((is_digit ch)
      (set start i)
      (while (and (lt i n) (is_digit (string_slice s i 1)))
        (set i (add i 1)))
      (println (fmt "NUM:{}" (string_slice s start (sub i start)))))
    ((eq ch "(")
      (println "LPAREN:(")
      (set i (add i 1)))
    ((eq ch ")")
      (println "RPAREN:)")
      (set i (add i 1)))
    (true
      (println (fmt "OP:{}" ch))
      (set i (add i 1)))))
