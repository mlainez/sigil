(set s $0)
(set n (len s))
(set i 0)
(while (lt i n)
  (set c (string_slice s i 1))
  (cond
    ((is_digit c)
      (set j i)
      (while (and (lt j n) (is_digit (string_slice s j 1)))
        (set j (add j 1)))
      (println (fmt "NUM {}" (string_slice s i (sub j i))))
      (set i j))
    ((eq c "(")
      (println "LPAREN")
      (set i (add i 1)))
    ((eq c ")")
      (println "RPAREN")
      (set i (add i 1)))
    (true
      (println (fmt "OP {}" c))
      (set i (add i 1)))))
