(set f (float $0))
(set cents_total (round (mul f 100.0)))
(set dollars (div cents_total 100))
(set cents (mod cents_total 100))
(set ds (str dollars))
(set n (len ds))
(set whole "")
(for i 0 n
  (set c (string_slice ds i 1))
  (set pos (sub n i))
  (if (and (gt i 0) (eq (mod pos 3) 0))
    (set whole (string_concat whole ",")))
  (set whole (string_concat whole c)))
(set cs (str cents))
(if (lt cents 10)
  (set cs (string_concat "0" cs)))
(println (fmt "${}.{}" whole cs))
