(set s $0)
(set vals {"I" 1 "V" 5 "X" 10 "L" 50 "C" 100 "D" 500 "M" 1000})
(set chars (chars s))
(set n (len chars))
(set total 0)
(for i 0 n
  (set v (map_get vals (array_get chars i)))
  (if (lt i (sub n 1))
    (set nx (map_get vals (array_get chars (add i 1))))
    (else (set nx 0)))
  (if (lt v nx)
    (set total (sub total v))
    (else (set total (add total v)))))
(println total)
