(set s $0)
(set hu false)
(set hl false)
(set hd false)
(set hs false)
(for-each c (chars s)
  (cond
    ((is_upper c) (set hu true))
    ((is_lower c) (set hl true))
    ((is_digit c) (set hd true))
    (true (set hs true))))
(if (and (and (ge (len s) 8) (and hu hl)) (and hd hs))
  (println "true")
  (else (println "false")))
