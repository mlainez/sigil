(set j (json_parse $0))
(set items (json_get j ["items"]))
(set field $1)
(set threshold #2)
(set filtered (filter items (\item (gt (json_get item [field]) threshold))))
(set sorted (sort_by filtered (\item (neg (json_get item [field])))))
(for-each item sorted
  (println (fmt "{}: {}" (json_get item ["name"]) (json_get item [field]))))
