(set n #0)
(set sieve [])
(for k 0 (add n 1)
  (push sieve true))
(set i 2)
(set j 0)
(while (le (mul i i) n)
  (if (array_get sieve i)
    (set j (mul i i))
    (while (le j n)
      (array_set sieve j false)
      (set j (add j i))))
  (set i (add i 1)))
(set buf [])
(for k 2 (add n 1)
  (if (array_get sieve k)
    (push buf k)
    (if (eq (len buf) 5)
      (println (join buf " "))
      (set buf []))))
(if (gt (len buf) 0)
  (println (join buf " ")))
