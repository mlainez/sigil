(set f float (float $0))
(set cents int (round (mul f 100.0)))
(set dollars int (div cents 100))
(set rem int (mod cents 100))
(set ds string (str dollars))
(set out string "")
(set n int (len ds))
(for i 0 n
  (set pos int (sub n i))
  (if (and (gt i 0) (eq (mod pos 3) 0))
    (set out (string_concat out ",")))
  (set out (string_concat out (string_slice ds i 1))))
(set cs string (str rem))
(if (lt rem 10) (set cs (string_concat "0" cs)))
(println (fmt "${}.{}" out cs))
