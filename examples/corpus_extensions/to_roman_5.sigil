(set vals array [1000 900 500 400 100 90 50 40 10 9 5 4 1])
(set syms array ["M" "CM" "D" "CD" "C" "XC" "L" "XL" "X" "IX" "V" "IV" "I"])
(set n int #0)
(set out string "")
(set i int 0)
(while (lt i (len vals))
  (set v int (array_get vals i))
  (while (ge n v)
    (set out (string_concat out (array_get syms i)))
    (set n (sub n v)))
  (set i (add i 1)))
(println out)
