(set s string $0)
(set n int (len s))
(set out "")
(for i 0 n
  (set c string (string_slice s i 1))
  (set count int 0)
  (for j 0 (add i 1)
    (if (eq (string_slice s j 1) c)
      (set count (add count 1))))
  (if (gt i 0)
    (set out (fmt "{} " out)))
  (set out (fmt "{}{}" out count)))
(println (fmt "{}\n" out))
