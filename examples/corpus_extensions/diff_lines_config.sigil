(set old_lines array (split $0 "\n"))
(set new_lines array (split $1 "\n"))

(set only_in_old array (filter (\line (not (in line new_lines))) old_lines))
(set only_in_new array (filter (\line (not (in line old_lines))) new_lines))

(for-each line string only_in_old
  (println (fmt "-{}" line)))

(for-each line string only_in_new
  (println (fmt "+{}" line)))
