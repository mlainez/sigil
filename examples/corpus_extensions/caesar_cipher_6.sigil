(set text $0)
(set shift (mod (add (mod #1 26) 26) 26))
(set result "")
(for-each c (chars text)
  (set code (string_get c 0))
  (cond
    ((and (ge code 65) (le code 90))
      (set result (string_concat result (char_from_code (add (mod (add (sub code 65) shift) 26) 65)))))
    ((and (ge code 97) (le code 122))
      (set result (string_concat result (char_from_code (add (mod (add (sub code 97) shift) 26) 97)))))
    (true (set result (string_concat result c)))))
(println result)
