(set s $0)
(set n (len s))
(set i 0)
(while (and (lt i n) (not (or (is_alpha (string_get s i)) (is_digit (string_get s i)))))
  (set i (add i 1)))
(set j (sub n 1))
(while (and (ge j i) (not (or (is_alpha (string_get s j)) (is_digit (string_get s j)))))
  (set j (sub j 1)))
(println (string_slice s i (add (sub j i) 1)))
