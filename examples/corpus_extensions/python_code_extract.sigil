(set lines (split $0 "\n"))
(set func_lines (filter lines (\line (string_contains line "def "))))
(set func_names (sort (map_arr func_lines (\line (first (split (last (split line "def ")) "("))))))
(set todo_lines (filter lines (\line (string_contains line "# TODO:"))))
(set todos (map_arr todo_lines (\line (last (split line "# TODO: ")))))
(println "Functions:")
(for-each f func_names (println (fmt "  %s" f)))
(println "TODOs:")
(for-each t todos (println (fmt "  %s" t)))
