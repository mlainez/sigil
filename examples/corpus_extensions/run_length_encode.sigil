(set s $0)
(set cs (chars s))
(set n (len cs))
(set out "")
(set i 0)
(while (lt i n)
  (set c (array_get cs i))
  (set count 1)
  (set j (add i 1))
  (while (and (lt j n) (eq (array_get cs j) c))
    (set count (add count 1))
    (set j (add j 1)))
  (set out (fmt "{}{}{}" out c count))
  (set i j))
(println out)
