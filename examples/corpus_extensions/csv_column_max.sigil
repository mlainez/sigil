(set csv string $0)
(set col string $1)
(set lines array (split csv "\n"))
(set headers array (split (first lines) ","))
(set idx int (array_index_of headers col))
(set rows array (rest lines))
(set vals array (map_arr rows (\r (int (array_get (split r ",") idx)))))
(set m int (first vals))
(for-each v int vals (if (gt v m) (set m v)))
(println m)
