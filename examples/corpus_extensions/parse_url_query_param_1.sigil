(set url $0)
(set key $1)
(set qstart (string_find url "?"))
(set query (string_slice url (add qstart 1) (sub (len url) (add qstart 1))))
(set pairs (split query "&"))
(set prefix (string_concat key "="))
(for-each p pairs
  (if (string_starts_with p prefix)
    (println (string_slice p (add (len key) 1) (sub (len p) (add (len key) 1))))))
