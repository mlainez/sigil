(set csv $0)
(set fcol #1)
(set op $2)
(set thr #3)
(set ocol #4)
(for-each row (split csv "\n")
  (set fields (split row ","))
  (set v (int (array_get fields fcol)))
  (set m false)
  (cond
    ((eq op ">") (set m (gt v thr)))
    ((eq op "<") (set m (lt v thr)))
    ((eq op "=") (set m (eq v thr))))
  (if m (println (array_get fields ocol))))
