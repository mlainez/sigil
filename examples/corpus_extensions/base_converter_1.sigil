(fn to_base n int b int -> string
  (if (eq n 0) (ret "0"))
  (set digits "0123456789abcdef")
  (set result "")
  (while (gt n 0)
    (set d (mod n b))
    (set result (string_concat (string_slice digits d 1) result))
    (set n (div n b)))
  (ret result))

(for i 0 (argv_count)
  (set s (arg_str i))
  (set n (arg_int i))
  (println (fmt "{}: bin={} oct={} hex={}" s (to_base n 2) (to_base n 8) (to_base n 16))))
