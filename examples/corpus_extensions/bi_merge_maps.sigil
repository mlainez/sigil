(set a {})
(for-each pair (split $0 ",")
  (set kv (split pair "="))
  (set a (map_set a (array_get kv 0) (array_get kv 1))))
(for-each pair (split $1 ",")
  (set kv (split pair "="))
  (set a (map_set a (array_get kv 0) (array_get kv 1))))
(set parts [])
(for-each k (sort (map_keys a))
  (set parts (push parts (fmt "{}={}" k (map_get a k)))))
(println (join parts ","))
