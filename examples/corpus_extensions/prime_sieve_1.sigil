(set n #0)
(set sieve [])
(for i 0 (add n 1) (push sieve true))
(array_set sieve 0 false)
(array_set sieve 1 false)
(for i 2 (add n 1)
  (if (array_get sieve i)
    (set j (mul i i))
    (while (le j n)
      (array_set sieve j false)
      (set j (add j i)))))
(set primes [])
(for i 2 (add n 1)
  (if (array_get sieve i)
    (push primes (str i))))
(println (join primes " "))
