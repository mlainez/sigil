(set n #0)
(set sieve [])
(for i 0 (add n 1)
  (push sieve (ge i 2)))
(set i 2)
(while (le (mul i i) n)
  (if (array_get sieve i)
    (set j (mul i i))
    (while (le j n)
      (array_set sieve j false)
      (set j (add j i))))
  (set i (add i 1)))
(set primes [])
(for k 2 (add n 1)
  (if (array_get sieve k)
    (push primes k)))
(println (join primes " "))
