(set nums (parse_ints $0))
(set n (len nums))
(set mean (div (float (sum nums)) (float n)))
(set ss 0.0)
(for-each x nums
  (set d (sub (float x) mean))
  (set ss (add ss (mul d d))))
(set v (div ss (float n)))
(set h (round (mul v 100.0)))
(set whole (div h 100))
(set frac (mod h 100))
(set fs (str frac))
(if (lt frac 10) (set fs (string_concat "0" fs)))
(println (fmt "{}.{}" whole fs))
