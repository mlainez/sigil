(set s $0)
(set chars (chars s))
(set n (len chars))
(set out "")
(set cur "")
(set count 0)
(for i 0 n
  (set c (array_get chars i))
  (if (eq c cur)
    (set count (add count 1))
    (else
      (if (gt count 0)
        (set out (fmt "{}{}{}" out cur count)))
      (set cur c)
      (set count 1))))
(if (gt count 0)
  (set out (fmt "{}{}{}" out cur count)))
(println out)
