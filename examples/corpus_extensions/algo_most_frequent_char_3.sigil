(set s $0)
(set counts {})
(set order [])
(for-each c (chars s)
  (if (not (in c counts))
    (push order c))
  (map_inc counts c))
(set best (first order))
(set bcount (map_get counts best))
(for-each c order
  (set cnt (map_get counts c))
  (if (gt cnt bcount)
    (set bcount cnt)
    (set best c)))
(println best)
