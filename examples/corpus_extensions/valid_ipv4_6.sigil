(set parts (split $0 "."))
(set valid (eq (len parts) 4))
(for-each p parts
  (if valid
    (cond
      ((eq (len p) 0) (set valid false))
      ((gt (len p) 3) (set valid false))
      ((and (gt (len p) 1) (eq (string_get p 0) 48)) (set valid false))
      (true
        (set ok true)
        (for-each c (chars p)
          (if (not (is_digit c)) (set ok false)))
        (if (not ok) (set valid false)
          (else
            (if (gt (int p) 255) (set valid false))))))))
(if valid (println "yes") (else (println "no")))
