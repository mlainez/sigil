(set csv $0)
(set filter $1)
(set parts (split filter "="))
(set col (first parts))
(set val (array_get parts 1))
(set rows (split csv "\n"))
(set headers (split (first rows) ","))
(set idx (array_index_of headers col))
(println (first rows))
(set n (len rows))
(for i 1 n
  (set row (array_get rows i))
  (set cols (split row ","))
  (if (eq (array_get cols idx) val)
    (println row)))
