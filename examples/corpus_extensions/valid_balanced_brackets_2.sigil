(set s $0)
(set stack [])
(set ok true)
(set i 0)
(set n (len s))
(while (and ok (lt i n))
  (set c (string_slice s i 1))
  (cond
    ((eq c "(") (push stack "("))
    ((eq c "[") (push stack "["))
    ((eq c "{") (push stack "{"))
    ((eq c ")")
      (if (or (eq (len stack) 0) (ne (array_pop stack) "("))
        (set ok false)))
    ((eq c "]")
      (if (or (eq (len stack) 0) (ne (array_pop stack) "["))
        (set ok false)))
    ((eq c "}")
      (if (or (eq (len stack) 0) (ne (array_pop stack) "{"))
        (set ok false))))
  (set i (add i 1)))
(println (and ok (eq (len stack) 0)))
