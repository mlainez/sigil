(set s $0)
(set result "")
(set n (len s))
(set i 0)
(while (lt i n)
  (set ch (string_slice s i 1))
  (set count 1)
  (set j (add i 1))
  (while (and (lt j n) (eq (string_slice s j 1) ch))
    (set count (add count 1))
    (set j (add j 1)))
  (set result (string_concat result (string_concat ch (str count))))
  (set i j))
(println result)
