(fn is_prime n int -> bool
  (if (lt n 2) (ret false))
  (if (eq n 2) (ret true))
  (if (eq (mod n 2) 0) (ret false))
  (set i 3)
  (while (le (mul i i) n)
    (if (eq (mod n i) 0) (ret false))
    (set i (add i 2)))
  (ret true))

(set n #0)
(set count 0)
(for i 2 n
  (if (is_prime i) (set count (add count 1))))
(println count)
