(set s $0)
(set counts {})
(set order [])
(for-each c (chars s)
  (if (not (in c counts))
    (push order c))
  (map_inc counts c))
(set best (first order))
(set bestn (map_get counts best))
(for-each c order
  (if (gt (map_get counts c) bestn)
    (set best c)
    (set bestn (map_get counts c))))
(println best)
