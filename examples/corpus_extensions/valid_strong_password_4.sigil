(set s $0)
(set has_upper false)
(set has_lower false)
(set has_digit false)
(for-each c (chars s)
  (cond
    ((is_upper c) (set has_upper true))
    ((is_lower c) (set has_lower true))
    ((is_digit c) (set has_digit true))))
(println (and (ge (len s) 8) (and has_upper (and has_lower has_digit))))
