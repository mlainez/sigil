(set vals [[1000 "M"] [900 "CM"] [500 "D"] [400 "CD"] [100 "C"] [90 "XC"] [50 "L"] [40 "XL"] [10 "X"] [9 "IX"] [5 "V"] [4 "IV"] [1 "I"]])
(set n #0)
(set result "")
(for-each pair vals
  (set v (first pair))
  (set s (last pair))
  (set count (div n v))
  (set result (join [result (join (map_arr (range count) (\_ s)) "")] ""))
  (set n (mod n v)))
(println result)
