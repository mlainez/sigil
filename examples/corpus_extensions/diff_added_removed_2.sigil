(set blob1 string $0)
(set blob2 string $1)

(set lines1 array (split blob1 "\n"))
(set lines2 array (split blob2 "\n"))

(set only_in_blob1 array (filter (\x (not (in x lines2))) lines1))
(set only_in_blob2 array (filter (\x (not (in x lines1))) lines2))

(for-each line string only_in_blob1
  (println (fmt "- {}" line)))

(for-each line string only_in_blob2
  (println (fmt "+ {}" line)))
