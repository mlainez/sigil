(set s $0)
(set result "")
(set cur "")
(set count 0)
(for-each c (chars s)
  (if (eq c cur)
    (set count (add count 1))
    (else
      (if (gt count 0)
        (set result (fmt "{}{}{}" result cur count)))
      (set cur c)
      (set count 1))))
(if (gt count 0)
  (set result (fmt "{}{}{}" result cur count)))
(println result)
