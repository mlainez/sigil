(set a string $0)
(set b string $1)
(set lena int (len a))
(set lenb int (len b))
(set i 0)
(set done bool false)
(while (and (not done) (ge (sub lena i) 1))
  (set ai string (string_slice a (sub lena (add i 1)) 1))
  (set bi string (string_slice b (sub lenb (add i 1)) 1))
  (if (eq ai bi)
    (set i (add i 1))
    (else (set done true))))
(println (string_slice a (sub lena i) i))
