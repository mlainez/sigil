(set n int #0)
(set parts array [])
(set p int 2)
(while (le (mul p p) n)
  (set k int 0)
  (while (eq (mod n p) 0)
    (set n (div n p))
    (set k (add k 1)))
  (if (eq k 1) (push parts (str p)))
  (if (gt k 1) (push parts (fmt "{}^{}" p k)))
  (set p (add p 1)))
(if (gt n 1) (push parts (str n)))
(println (join parts " * "))
