(set f float (float $0))
(set cents int (round (mul f 100.0)))
(set dollars int (div cents 100))
(set cp int (mod cents 100))
(set ds string (str dollars))
(set n int (len ds))
(set out string "")
(for i 0 n
  (set pfe int (sub (sub n 1) i))
  (if (and (gt i 0) (eq (mod pfe 3) 2))
    (set out (string_concat out ",")))
  (set out (string_concat out (string_slice ds i 1))))
(set cs string (str cp))
(if (lt cp 10)
  (set cs (string_concat "0" cs)))
(println (fmt "${}.{}" out cs))
