(set s $0)
(set result "")
(set i 0)
(set n (len s))
(while (lt i n)
  (set c (string_slice s i 1))
  (set count 1)
  (while (and (lt (add i count) n) (eq (string_slice s (add i count) 1) c))
    (set count (add count 1)))
  (set result (string_concat result (string_concat c (str count))))
  (set i (add i count)))
(println result)
