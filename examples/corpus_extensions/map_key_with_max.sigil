(set pairs (sort (split $0 ",")))
(set kv0 (split (array_get pairs 0) "="))
(set best_key (array_get kv0 0))
(set best_val (int (array_get kv0 1)))
(for i 1 (len pairs)
  (set kv (split (array_get pairs i) "="))
  (set k (array_get kv 0))
  (set v (int (array_get kv 1)))
  (if (gt v best_val)
    (set best_key k)
    (set best_val v)))
(println best_key)
