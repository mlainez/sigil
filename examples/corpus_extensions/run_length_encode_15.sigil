(set s string $0)
(set n int (len s))
(set out string "")
(set i int 0)
(while (lt i n)
  (set c string (string_slice s i 1))
  (set count int 1)
  (while (and (lt (add i count) n) (eq (string_slice s (add i count) 1) c))
    (set count (add count 1)))
  (set out (fmt "{}{}{}" out c count))
  (set i (add i count)))
(println out)
