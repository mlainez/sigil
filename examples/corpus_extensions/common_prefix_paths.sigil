(set p1 $0)
(set p2 $1)
(set n1 (len p1))
(set n2 (len p2))
(set i 0)
(while (and (lt i n1) (lt i n2))
  (if (ne (string_get p1 i) (string_get p2 i)) (break))
  (set i (add i 1)))
(if (ge i 0)
  (set j 0)
  (while (and (gt i 0) (ne (string_slice p1 (sub i 1) 1) "/"))
    (set i (sub i 1))
    (set j (add j 1)))
  (println (fmt "{}\n" (string_slice p1 0 (add i j))))
  (else
    (println "/")))
