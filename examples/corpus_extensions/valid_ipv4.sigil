(fn valid_octet s string -> bool
  (set n (len s))
  (if (eq n 0) (ret false))
  (if (gt n 3) (ret false))
  (if (and (gt n 1) (eq (string_get s 0) 48)) (ret false))
  (for i 0 n
    (if (not (is_digit (string_get s i))) (ret false)))
  (if (gt (int s) 255) (ret false))
  (ret true))

(set parts (split $0 "."))
(if (ne (len parts) 4)
  (println "no")
  (else
    (set ok true)
    (for-each p parts
      (if (not (valid_octet p)) (set ok false)))
    (if ok (println "yes") (else (println "no")))))
