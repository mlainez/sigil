(set arr (chars $0))
(set n (len arr))
(set out "")
(set i 0)
(while (lt i n)
  (set c (array_get arr i))
  (set count 1)
  (while (and (lt (add i count) n) (eq (array_get arr (add i count)) c))
    (set count (add count 1)))
  (set out (fmt "{}{}{}" out c count))
  (set i (add i count)))
(println out)
