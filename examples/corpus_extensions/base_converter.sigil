(set digits "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ")
(set s (upper $0))
(set fb #1)
(set tb #2)
(set n 0)
(for i 0 (len s)
  (set ch (string_slice s i 1))
  (set n (add (mul n fb) (string_find digits ch))))
(if (eq n 0)
  (println "0")
  (else
    (set out "")
    (while (gt n 0)
      (set out (string_concat (string_slice digits (mod n tb) 1) out))
      (set n (div n tb)))
    (println out)))
