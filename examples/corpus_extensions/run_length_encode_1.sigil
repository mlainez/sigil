(set s $0)
(set result "")
(set chars (chars s))
(set n (len chars))
(set i 0)
(while (lt i n)
  (set c (array_get chars i))
  (set count 1)
  (set j (add i 1))
  (while (and (lt j n) (eq (array_get chars j) c))
    (set count (add count 1))
    (set j (add j 1)))
  (set result (fmt "{}{}{}" result c count))
  (set i j))
(println result)
