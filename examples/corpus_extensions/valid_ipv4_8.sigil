(fn valid_octet p string -> bool
  (set n (len p))
  (if (or (lt n 1) (gt n 3)) (ret false))
  (if (and (gt n 1) (string_starts_with p "0")) (ret false))
  (for-each c (chars p)
    (if (not (is_digit c)) (ret false)))
  (if (gt (int p) 255) (ret false))
  (ret true))

(set s $0)
(set parts (split s "."))
(set ok true)
(if (ne (len parts) 4) (set ok false))
(if ok
  (for-each p parts
    (if (not (valid_octet p)) (set ok false))))
(if ok (println "yes") (else (println "no")))
