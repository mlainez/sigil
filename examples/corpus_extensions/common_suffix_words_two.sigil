(set a (rev (split $0 " ")))
(set b (rev (split $1 " ")))
(set n (len a))
(set m (len b))
(set lim (if (lt n m) n m))
(set i 0)
(set done false)
(for-each k (range 0 lim)
  (if (and (not done) (eq (get_or a k "") (get_or b k "")))
    (set i (add k 1))
    (set done true)))
(println (join (rev (slice a 0 i)) " "))
