(set s $0)
(set stack [])
(set ok true)
(for-each c (chars s)
  (cond
    ((eq c "(") (push stack ")"))
    ((eq c "[") (push stack "]"))
    ((eq c "{") (push stack "}"))
    ((in c ")]}")
      (if (eq (len stack) 0)
        (set ok false)
        (else
          (set top (array_pop stack))
          (if (ne top c) (set ok false)))))))
(if (gt (len stack) 0) (set ok false))
(println ok)
