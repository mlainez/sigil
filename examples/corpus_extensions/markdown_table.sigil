(set input $0)
(set lines (split input "\n"))
(set headers (filter (\c (gt (len c) 0)) (map_arr (\c (trim c)) (split (array_get lines 0) "|"))))
(for i 2 (len lines)
  (set cells (filter (\c (gt (len c) 0)) (map_arr (\c (trim c)) (split (array_get lines i) "|"))))
  (set parts [])
  (for j 0 (len headers)
    (push parts (fmt "{}: {}" (array_get headers j) (array_get cells j))))
  (println (join parts ", ")))
