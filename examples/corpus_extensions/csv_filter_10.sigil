(set rows (split $0 "\n"))
(set header (first rows))
(set col_names (split header ","))
(set col_idx (first (first (filter (enumerate col_names) (\p (eq (last p) $1))))))
(println header)
(for-each row (rest rows)
  (if (ne row "")
    (if (eq (first (slice (split row ",") col_idx (+ col_idx 1))) $2)
      (println row))))
