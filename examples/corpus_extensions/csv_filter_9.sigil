(set rows (split $0 "\n"))
(set header (first rows))
(set header_fields (split header ","))
(set col_idx (first (first (filter (enumerate header_fields) (\pair (eq (last pair) $1))))))
(println header)
(for-each row (rest rows)
  (set row_fields (split row ","))
  (if (eq (get_or row_fields col_idx "") $2)
    (println row)))
