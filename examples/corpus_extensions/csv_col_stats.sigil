(set col #0)
(set s 0)
(set n 0)
(set total (argv_count))
(for i 1 total
  (set v (int (array_get (split (arg_str i) ",") col)))
  (set s (add s v))
  (set n (add n 1)))
(println (fmt "sum: {}" s))
(println (fmt "count: {}" n))
(set mx100 (div (add (mul s 100) (div n 2)) n))
(set whole (div mx100 100))
(set frac (mod mx100 100))
(set fracstr (str frac))
(cond ((lt frac 10) (set fracstr (fmt "0{}" frac))))
(println (fmt "mean: {}.{}" whole fracstr))
