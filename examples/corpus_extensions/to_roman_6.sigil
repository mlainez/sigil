(set values array [1000 900 500 400 100 90 50 40 10 9 5 4 1 1])
(set numerals array ["M" "CM" "D" "CD" "C" "XC" "L" "XL" "X" "IX" "V" "IV" "I" ""])
(set num int #0)
(set result string "")
(for-each i int (range 0 (len values))
  (while (ge num (array_get values i))
    (set result (str result (array_get numerals i)))
    (set num (sub num (array_get values i)))))
(println result)
