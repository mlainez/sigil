(set s $0)
(set stack [])
(set ok true)
(set pairs {")" "(" "]" "[" "}" "{"})
(for-each c (chars s)
  (cond
    ((in c "([{") (push stack c))
    ((in c ")]}")
      (if (or (eq (len stack) 0) (ne (array_pop stack) (map_get pairs c)))
        (set ok false)))))
(println (and ok (eq (len stack) 0)))
