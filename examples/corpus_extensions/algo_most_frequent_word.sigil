(set words (split $0 " "))
(set counts {})
(for-each w words (map_inc counts w))
(set best "")
(set best_count 0)
(set seen {})
(for-each w words
  (if (not (map_has seen w))
    (set seen (map_set seen w true))
    (set cnt (map_get counts w))
    (if (gt cnt best_count)
      (set best w)
      (set best_count cnt))))
(println best)
