(set n (argv_count))
(set prefix "")
(if (gt n 0)
  (set prefix $0)
  (set j 1)
  (while (lt j n)
    (set s (arg_str j))
    (set i 0)
    (set max_i (min (len prefix) (len s)))
    (while (and (lt i max_i) (eq (string_slice prefix i 1) (string_slice s i 1)))
      (set i (add i 1)))
    (set prefix (string_slice prefix 0 i))
    (set j (add j 1))))
(println prefix)
