(set s $0)
(set counts {})
(for-each c (chars s)
  (if (or (is_alpha c) (is_digit c))
    (map_inc counts c)))
(set best "")
(set best_count 0)
(for-each k (map_keys counts)
  (set v (map_get counts k))
  (if (or (gt v best_count) (and (eq v best_count) (lt k best)))
    (set best k)
    (set best_count v)))
(println best)
