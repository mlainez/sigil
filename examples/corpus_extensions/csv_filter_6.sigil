(set csv $0)
(set col $1)
(set val $2)
(set rows (split csv "\n"))
(set header (array_get rows 0))
(set fields (split header ","))
(set idx (array_index_of fields col))
(println header)
(for i 1 (len rows)
  (set row (array_get rows i))
  (set parts (split row ","))
  (if (eq (array_get parts idx) val)
    (println row)))
