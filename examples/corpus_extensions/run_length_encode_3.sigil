(set s $0)
(set out "")
(set n (len s))
(set i 0)
(while (lt i n)
  (set c (string_slice s i 1))
  (set count 1)
  (set j (add i 1))
  (while (and (lt j n) (eq (string_slice s j 1) c))
    (set count (add count 1))
    (set j (add j 1)))
  (set out (string_concat out (fmt "{}{}" c count)))
  (set i j))
(println out)
