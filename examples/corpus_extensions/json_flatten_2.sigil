(fn flatten j json prefix string -> unit
  (cond
    ((is_object j)
      (for-each k string (map_keys j)
        (set np string "")
        (if (eq (len prefix) 0)
          (set np k)
          (else (set np (fmt "{}.{}" prefix k))))
        (flatten (json_get j k) np)))
    (true
      (println (fmt "{}={}" prefix (json_stringify j))))))

(set j json (json_parse $0))
(flatten j "")
