(set s $0)
(set cs (chars s))
(set n (len cs))
(set total 0)
(for i 0 n
  (set d (string_to_int (array_get cs i)))
  (set pos (sub (sub n 1) i))
  (if (eq (mod pos 2) 1)
    (set d (mul d 2))
    (if (gt d 9) (set d (sub d 9))))
  (set total (add total d)))
(if (eq (mod total 10) 0)
  (println "valid")
  (else (println "invalid")))
