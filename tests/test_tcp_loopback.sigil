(module test_tcp_loopback

  (fn test_tcp_send_receive -> int
    (set port 18701)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (set msg "hello from client")
    (tcp_send client msg)
    (set received (tcp_receive accepted 1024))
    (tcp_close client)
    (tcp_close accepted)
    (tcp_close server)
    (if (string_equals received msg)
      (ret 1))
    (ret 0))

  (fn test_tcp_server_to_client -> int
    (set port 18702)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (set msg "hello from server")
    (tcp_send accepted msg)
    (set received (tcp_receive client 1024))
    (tcp_close client)
    (tcp_close accepted)
    (tcp_close server)
    (if (string_equals received msg)
      (ret 1))
    (ret 0))

  (fn test_tcp_bidirectional -> int
    (set port 18703)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (set msg1 "ping")
    (tcp_send client msg1)
    (set got1 (tcp_receive accepted 1024))
    (set msg2 "pong")
    (tcp_send accepted msg2)
    (set got2 (tcp_receive client 1024))
    (tcp_close client)
    (tcp_close accepted)
    (tcp_close server)
    (set ok1 (string_equals got1 msg1))
    (set ok2 (string_equals got2 msg2))
    (if ok1
      (if ok2
        (ret 1)))
    (ret 0))

  (fn test_tcp_large_message -> int
    (set port 18704)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (set msg "ABCDEFGHIJ")
    (set big_msg msg)
    (set i 0)
    (while (lt i 6)
      (set big_msg (add big_msg big_msg))
      (set i (add i 1)))
    (set expected_len (len big_msg))
    (tcp_send client big_msg)
    (set received "")
    (set total_len 0)
    (while (lt total_len expected_len)
      (set chunk (tcp_receive accepted 4096))
      (set chunk_len (len chunk))
      (if (eq chunk_len 0)
        (set total_len expected_len)
        (else
          (set received (add received chunk))
          (set total_len (len received)))))
    (tcp_close client)
    (tcp_close accepted)
    (tcp_close server)
    (set recv_len (len received))
    (if (eq recv_len expected_len)
      (ret 1))
    (ret 0))

  (fn test_tcp_socket_select -> int
    (set port 18705)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (set msg "select test")
    (tcp_send client msg)
    (sleep 20)
    (set inputs [])
    (push inputs accepted)
    (set ready (socket_select inputs))
    (set ready_count (len ready))
    (tcp_close client)
    (tcp_close accepted)
    (tcp_close server)
    (if (gt ready_count 0)
      (ret 1))
    (ret 0))

  (fn test_tcp_close_detection -> int
    (set port 18706)
    (set server socket (tcp_listen port))
    (set client socket (tcp_connect "127.0.0.1" port))
    (set accepted socket (tcp_accept server))
    (tcp_close client)
    (sleep 20)
    (set data (tcp_receive accepted 1024))
    (set data_len (len data))
    (tcp_close accepted)
    (tcp_close server)
    (if (eq data_len 0)
      (ret 1))
    (ret 0))

  (test-spec test_tcp_send_receive
    (case "client sends message to server via loopback"
      (input)
      (expect 1)))

  (test-spec test_tcp_server_to_client
    (case "server sends message to client via loopback"
      (input)
      (expect 1)))

  (test-spec test_tcp_bidirectional
    (case "bidirectional ping-pong over TCP loopback"
      (input)
      (expect 1)))

  (test-spec test_tcp_large_message
    (case "sends and receives a large message (640 bytes)"
      (input)
      (expect 1)))

  (test-spec test_tcp_socket_select
    (case "socket_select detects readable socket"
      (input)
      (expect 1)))

  (test-spec test_tcp_close_detection
    (case "detects closed connection via empty receive"
      (input)
      (expect 1)))

  (meta-note "Tests TCP loopback: send/receive, bidirectional, large messages, socket_select, close detection"))
