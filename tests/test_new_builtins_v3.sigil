(let t1 (tokens "  hello   world  foo "))
(println (join t1 ","))
(let t2 (tokens "the quick  brown  fox"))
(println (len t2))
(println (squeeze "  hello   world  foo "))
(let bs (split_blocks "hello\nworld\n\nfoo\nbar\nbaz\n\nlast"))
(println (len bs))
(println (get bs 0))
(println (get bs 1))
(println (get bs 2))
(let m (find_all "[0-9]+" "log on 2024-01-15: ok, 7 errors at 23ms"))
(println (join m ","))
