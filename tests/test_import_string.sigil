(module test_import_string
  (import string_utils)
  
  (fn get_length -> int
    (set text "hello world")
    (set len (len text))
    (ret len))
  
  (test-spec get_length
    (case "gets length of hello world string"
      (input)
      (expect 11)))
  
  (meta-note "Tests len with string_utils import"))
