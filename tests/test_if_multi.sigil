(module test_if_multi
  (fn test_multi x int -> bool
    (set result false)
    (set check (gt x 0))
    (if check
      (set temp true)
      (set result temp)
      (else))
    (ret result))
  
  (test-spec test_multi
    (case "returns true for positive numbers"
      (input 5)
      (expect true))
    (case "returns false for zero"
      (input 0)
      (expect false))
    (case "returns false for negative numbers"
      (input -3)
      (expect false)))
  
  (meta-note "Tests if statement with multiple statements in body"))
