(module test_for_loop_edge
  (fn loop_var_value -> int
    (set last -1)
    (for i 0 5
      (set last i))
    (ret last))

  (test-spec loop_var_value
    (case "loop var holds last value 4"
      (input)
      (expect 4)))

  (fn early_return_from_for arr array target int -> int
    (set len int (len arr))
    (for i 0 len
      (if (eq (array_get arr i) target)
        (ret i)))
    (ret -1))

  (test-spec early_return_from_for
    (case "finds target at index 2"
      (input [10 20 30 40] 30)
      (expect 2))
    (case "returns -1 when not found"
      (input [10 20 30] 99)
      (expect -1))
    (case "finds at index 0"
      (input [5 10 15] 5)
      (expect 0)))

  (fn computed_bounds n int -> int
    (set total 0)
    (set start int (sub n 3))
    (set end_val int (add n 2))
    (for i start end_val
      (set total (add total i)))
    (ret total))

  (test-spec computed_bounds
    (case "n=5, range [2,7) = 2+3+4+5+6=20"
      (input 5)
      (expect 20)))

  (fn for_inside_foreach -> int
    (set arrs array [[1 2] [3 4] [5 6]])
    (set total 0)
    (for-each sub_arr array arrs
      (set sub_len int (len sub_arr))
      (for j 0 sub_len
        (set total (add total (array_get sub_arr j)))))
    (ret total))

  (test-spec for_inside_foreach
    (case "sum all elements across sub-arrays = 21"
      (input)
      (expect 21)))

  (fn nested_break -> int
    (set total 0)
    (for i 0 10
      (for j 0 10
        (if (eq j 3) (break))
        (set total (add total 1))))
    (ret total))

  (test-spec nested_break
    (case "inner break at j=3, 10 outer * 3 inner = 30"
      (input)
      (expect 30)))

  (fn single_iteration -> int
    (set val 0)
    (for i 0 1
      (set val i))
    (ret val))

  (test-spec single_iteration
    (case "single iteration sets val to 0"
      (input)
      (expect 0)))

  (meta-note "Edge case tests for the for counting loop"))
