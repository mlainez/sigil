(module test_new_modules
  (import string_utils)
  (import filesystem)
  (import network)
  (import text_utils)
  
  (fn test_file_operations -> int
    (set test_file "/tmp/sigil_test.txt")
    (set success (write_file_safe test_file "Hello Sigil!"))
    (if (not success)
      (ret 0))
    (set content (read_file_safe test_file))
    (set deleted (delete_if_exists test_file))
    (if deleted
      (ret 1))
    (ret 0))
  
  (fn test_valid_port -> int
    (set valid (is_valid_port 8080))
    (if valid
      (ret 1))
    (ret 0))
  
  (fn test_invalid_port -> int
    (set invalid (is_valid_port 70000))
    (if (not invalid)
      (ret 1))
    (ret 0))
  
  (fn test_build_url -> int
    (set url (build_url "localhost" 8080 "/api/v1"))
    (set expected "http://localhost:8080/api/v1")
    (set matches (string_equals url expected))
    (if matches
      (ret 1))
    (ret 0))
  
  (fn test_repeat_string -> int
    (set repeated (repeat_string "x" 5))
    (set expected "xxxxx")
    (set matches (string_equals repeated expected))
    (if matches
      (ret 1))
    (ret 0))
  
  (fn test_pad_left -> int
    (set padded (pad_left "42" 5 "0"))
    (set expected "00042")
    (set matches (string_equals padded expected))
    (if matches
      (ret 1))
    (ret 0))
  
  (fn test_reverse_string -> int
    (set reversed (reverse_string "Sigil"))
    (set expected "ligiS")
    (set matches (string_equals reversed expected))
    (if matches
      (ret 1))
    (ret 0))
  
  (fn test_is_empty -> int
    (set empty (is_empty ""))
    (if empty
      (ret 1))
    (ret 0))
  
  (fn test_is_not_empty -> int
    (set not_empty (is_empty "text"))
    (if (not not_empty)
      (ret 1))
    (ret 0))
  
  (test-spec test_file_operations
    (case "writes, reads, and deletes file"
      (input)
      (expect 1)))
  
  (test-spec test_valid_port
    (case "validates port 8080"
      (input)
      (expect 1)))
  
  (test-spec test_invalid_port
    (case "rejects invalid port 70000"
      (input)
      (expect 1)))
  
  (test-spec test_build_url
    (case "builds URL from components"
      (input)
      (expect 1)))
  
  (test-spec test_repeat_string
    (case "repeats x five times"
      (input)
      (expect 1)))
  
  (test-spec test_pad_left
    (case "pads 42 with zeros"
      (input)
      (expect 1)))
  
  (test-spec test_reverse_string
    (case "reverses Sigil to ligiS"
      (input)
      (expect 1)))
  
  (test-spec test_is_empty
    (case "detects empty string"
      (input)
      (expect 1)))
  
  (test-spec test_is_not_empty
    (case "detects non-empty string"
      (input)
      (expect 1)))
  
  (meta-note "Tests filesystem, network, and text_utils modules"))
