(module test_tier3_batch2
  (fn diff_strings -> string
    (ret (join (diff ["a" "b" "c" "d"] ["b" "d"]) ",")))

  (test-spec diff_strings
    (case "elements in first but not second"
      (input)
      (expect "a,c")))

  (fn diff_empty_second -> string
    (ret (join (diff ["a" "b"] []) ",")))

  (test-spec diff_empty_second
    (case "diff against empty returns first unchanged"
      (input)
      (expect "a,b")))

  (fn diff_ints -> string
    (ret (join (diff [1 2 3 4 5] [2 4]) ",")))

  (test-spec diff_ints
    (case "int arrays"
      (input)
      (expect "1,3,5")))

  (fn inter_basic -> string
    (ret (join (inter ["a" "b" "c"] ["b" "c" "d"]) ",")))

  (test-spec inter_basic
    (case "intersection preserves first-array order"
      (input)
      (expect "b,c")))

  (fn inter_no_overlap -> int
    (ret (len (inter ["a" "b"] ["c" "d"]))))

  (test-spec inter_no_overlap
    (case "disjoint arrays return empty"
      (input)
      (expect 0)))

  (fn inter_dedupes -> string
    (ret (join (inter ["a" "a" "b"] ["a" "b"]) ",")))

  (test-spec inter_dedupes
    (case "duplicates in first removed in intersection"
      (input)
      (expect "a,b")))

  (fn union_preserves_order -> string
    (ret (join (union ["a" "b"] ["c" "b" "d"]) ",")))

  (test-spec union_preserves_order
    (case "union dedupes, preserves first occurrence"
      (input)
      (expect "a,b,c,d")))

  (fn fmt_float_basic -> string
    (ret (fmt_float 1.66667d 2)))

  (test-spec fmt_float_basic
    (case "decimal with 2 decimal places"
      (input)
      (expect "1.67")))

  (fn fmt_float_int_input -> string
    (ret (fmt_float 10 3)))

  (test-spec fmt_float_int_input
    (case "int input formats with trailing zeros"
      (input)
      (expect "10.000")))

  (fn fmt_float_zero_prec -> string
    (ret (fmt_float 3.7 0)))

  (test-spec fmt_float_zero_prec
    (case "zero precision rounds to int"
      (input)
      (expect "4")))

  (fn slice_array_basic -> string
    (ret (join (slice [1 2 3 4 5] 1 4) ",")))

  (test-spec slice_array_basic
    (case "half-open slice"
      (input)
      (expect "2,3,4")))

  (fn slice_negative_start -> string
    (ret (join (slice [1 2 3 4 5] -2 5) ",")))

  (test-spec slice_negative_start
    (case "negative start counts from end"
      (input)
      (expect "4,5")))

  (fn slice_no_end -> string
    (ret (join (slice [1 2 3 4 5] 2) ",")))

  (test-spec slice_no_end
    (case "omit end to take to last"
      (input)
      (expect "3,4,5")))

  (fn slice_string_negative -> string
    (ret (slice "hello world" -5)))

  (test-spec slice_string_negative
    (case "string slice with negative start"
      (input)
      (expect "world")))

  (fn slice_empty -> int
    (ret (len (slice [1 2 3] 2 1))))

  (test-spec slice_empty
    (case "empty slice when end < start"
      (input)
      (expect 0)))

  (fn merge_rightmost_wins -> string
    (set m (merge {"a" "1" "b" "2"} {"b" "20" "c" "3"}))
    (ret (map_get m "b")))

  (test-spec merge_rightmost_wins
    (case "later maps override"
      (input)
      (expect "20")))

  (fn merge_keeps_unique -> int
    (set m (merge {"a" "1"} {"b" "2"} {"c" "3"}))
    (ret (len m)))

  (test-spec merge_keeps_unique
    (case "three disjoint maps combine"
      (input)
      (expect 3)))

  (fn range_end -> string
    (ret (join (range 5) ",")))

  (test-spec range_end
    (case "range(5) produces 0..4"
      (input)
      (expect "0,1,2,3,4")))

  (fn range_start_end -> string
    (ret (join (range 2 7) ",")))

  (test-spec range_start_end
    (case "range(2,7) exclusive upper"
      (input)
      (expect "2,3,4,5,6")))

  (fn range_empty -> int
    (ret (len (range 5 3))))

  (test-spec range_empty
    (case "end < start is empty"
      (input)
      (expect 0)))

  (fn entries_basic -> int
    (set m (counter ["a" "b" "a"]))
    (set es (entries m))
    (ret (len es)))

  (test-spec entries_basic
    (case "entries returns one pair per key"
      (input)
      (expect 2)))

  (fn entries_pair_shape -> string
    (set m {"x" "1" "y" "2"})
    (set e (array_get (entries m) 0))
    (ret (add (array_get e 0) (add "=" (array_get e 1)))))

  (test-spec entries_pair_shape
    (case "each entry is a [key value] array"
      (input)
      (expect "x=1")))

  (fn entries_ranked_sort -> string
    (set m (counter ["the" "cat" "the" "dog" "the" "cat"]))
    (set ranked (sort_by (entries m) (\e [ (neg (array_get e 1)) (array_get e 0) ])))
    (ret (join (map_arr ranked (\e (fmt "{}:{}" (array_get e 0) (array_get e 1)))) ",")))

  (test-spec entries_ranked_sort
    (case "counter + entries + multi-key sort"
      (input)
      (expect "the:3,cat:2,dog:1")))

  (fn multi_key_sort -> string
    (set pairs [["the" 3] ["cat" 2] ["dog" 1] ["and" 2]])
    (set sorted (sort_by pairs (\p [ (neg (array_get p 1)) (array_get p 0) ])))
    (ret (join (map_arr sorted (\p (array_get p 0))) ",")))

  (test-spec multi_key_sort
    (case "sort by count desc then key asc"
      (input)
      (expect "the,and,cat,dog")))

  (fn enumerate_basic -> string
    (set es (enumerate ["a" "b" "c"]))
    (ret (join (map_arr es (\p (fmt "{}:{}" (array_get p 0) (array_get p 1)))) ",")))

  (test-spec enumerate_basic
    (case "index + value pairs"
      (input)
      (expect "0:a,1:b,2:c")))

  (fn enumerate_empty -> int
    (ret (len (enumerate []))))

  (test-spec enumerate_empty
    (case "empty array → empty enumeration"
      (input)
      (expect 0)))

  (fn scan_sum -> string
    (ret (join (scan [1 2 3 4] (\(a x) (add a x)) 0) ",")))

  (test-spec scan_sum
    (case "prefix sums"
      (input)
      (expect "1,3,6,10")))

  (fn scan_with_seed -> string
    (ret (join (scan [5 10 15] (\(a x) (add a x)) 100) ",")))

  (test-spec scan_with_seed
    (case "init is seed but not prepended"
      (input)
      (expect "105,115,130")))

  (fn scan_empty -> int
    (ret (len (scan [] (\(a x) (add a x)) 0))))

  (test-spec scan_empty
    (case "empty input → empty output"
      (input)
      (expect 0)))

  (fn scan_max_running -> string
    (ret (join (scan [3 1 4 1 5 9 2 6] (\(a x) (max a x)) 0) ",")))

  (test-spec scan_max_running
    (case "running maximum"
      (input)
      (expect "3,3,4,4,5,9,9,9")))

  (fn map_kv_fmt -> string
    (set m {"x" "1" "y" "2"})
    (ret (join (map_kv m (\(k v) (fmt "{}={}" k v))) ",")))

  (test-spec map_kv_fmt
    (case "fn receives k and v as separate args"
      (input)
      (expect "x=1,y=2")))

  (fn map_pairs_enumerate -> string
    (ret (join (map_pairs (enumerate ["a" "b" "c"]) (\(i v) (fmt "{}:{}" i v))) ",")))

  (test-spec map_pairs_enumerate
    (case "pair destructuring over enumerate output"
      (input)
      (expect "0:a,1:b,2:c")))

  (fn map_pairs_running_avg -> string
    (set sums (scan [10 20 30 40] (\(a x) (add a x)) 0))
    (ret (join (map_pairs (enumerate sums) (\(i s) (fmt_float (div (float s) (float (add i 1))) 1))) " ")))

  (test-spec map_pairs_running_avg
    (case "scan + enumerate + map_pairs = running average"
      (input)
      (expect "10.0 15.0 20.0 25.0")))

  (fn map_pairs_rejects_non_pair -> string
    (try
      (map_pairs [[1 2] [3]] (\(a b) (add a b)))
      (ret "no error")
      (catch err string
        (ret "caught"))))

  (test-spec map_pairs_rejects_non_pair
    (case "ragged input is rejected"
      (input)
      (expect "caught")))

  (fn map_kv_counts_upper -> string
    (set c (counter ["a" "b" "a" "c" "a" "b"]))
    (ret (join (map_kv c (\(k n) (fmt "{}*{}" (upper k) n))) " ")))

  (test-spec map_kv_counts_upper
    (case "works on counter output"
      (input)
      (expect "A*3 B*2 C*1")))

  (meta-note "Tests for diff/inter/union/fmt_float/slice/merge/range/entries/enumerate/scan/map_kv and multi-key sort_by — added 2026-04-23"))
